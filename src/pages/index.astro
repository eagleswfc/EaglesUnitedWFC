---
import BaseLayout from '../layouts/BaseLayout.astro';
import InfoCard from '../components/InfoCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import SocialLinks from '../components/SocialLinks.astro';
import Sponsors from '../components/Sponsors.astro';
import { getHomePage, getSiteSettings, multilineToHtml } from '../lib/content';

const settings = await getSiteSettings();
const home = await getHomePage();
const email = settings.contactEmail ?? 'eaglesuniteduk@gmail.com';
---

<BaseLayout
  title="Eagles United WFC | Women's Football in Haringey"
  description={home.heroSubtitle}
  settings={settings}
>
  <section class="relative overflow-hidden border-b border-white/10">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(225,29,72,0.25),transparent_55%)]"></div>
    <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(26,26,26,0.2),rgba(26,26,26,1))]"></div>

    <div class="relative mx-auto flex max-w-6xl flex-col items-center gap-8 px-4 py-16 text-center sm:px-6 sm:py-24 lg:px-8">
      <img
        src="/images/EaglesUnitedWFC_Logo.png"
        alt="Eagles United WFC logo"
        width="140"
        height="140"
        class="h-28 w-28 rounded-full ring-4 ring-white/15 sm:h-36 sm:w-36"
        loading="eager"
      />
      <div class="max-w-3xl space-y-4">
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-eagles-red">Est. 2024</p>
        <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl">
          {home.heroTitle}
        </h1>
        <p class="text-lg text-white/80 sm:text-xl">{home.heroSubtitle}</p>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a
          href="/contact"
          class="rounded-full bg-eagles-red px-6 py-3 text-sm font-bold uppercase tracking-wide text-white transition hover:bg-eagles-red-dark"
        >
          Get in Touch
        </a>
        <a
          href={`mailto:${email}`}
          class="rounded-full border border-white/20 px-6 py-3 text-sm font-bold uppercase tracking-wide text-white transition hover:border-white hover:bg-white/5"
        >
          Email Us
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-6 md:grid-cols-3">
      <InfoCard
        title={home.trainingHeading ?? 'Training'}
        body={multilineToHtml(home.trainingDetails)}
      />
      <InfoCard
        title={home.ageGroupHeading ?? 'Age Group'}
        body={multilineToHtml(home.ageGroupDetails)}
      />
      <InfoCard
        title={home.priceHeading ?? 'Price'}
        body={multilineToHtml(home.priceDetails)}
      />
    </div>
  </section>

  <section class="border-y border-white/10 bg-charcoal-light/40 py-16">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <SectionHeading title={home.ctaHeading ?? 'Ready to join?'} subtitle={home.ctaText} />
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a
          href="/contact"
          class="rounded-full bg-eagles-red px-6 py-3 text-sm font-bold uppercase tracking-wide text-white transition hover:bg-eagles-red-dark"
        >
          Contact Us
        </a>
        <a
          href="/about"
          class="rounded-full border border-white/20 px-6 py-3 text-sm font-bold uppercase tracking-wide text-white transition hover:bg-white/5"
        >
          Our Story
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8">
    <SectionHeading eyebrow="Community" title="Stay Connected" />
    <div class="mt-8 flex justify-center">
      <SocialLinks links={settings.socialLinks} />
    </div>
  </section>

  <Sponsors sponsors={settings.sponsors} />
</BaseLayout>
