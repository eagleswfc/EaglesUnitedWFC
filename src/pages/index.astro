---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import GalleryCarousel from '../components/GalleryCarousel';
import InfoCard from '../components/InfoCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import SocialLinks from '../components/SocialLinks.astro';
import Sponsors from '../components/Sponsors.astro';
import JukeboxAchievements from '../components/JukeboxAchievements';
import { imageUrl } from '../lib/image';
import { sanityClient } from '../lib/sanity';
import {
  blocksToParagraphs,
  getAboutPage,
  getAchievementsPage,
  getFooterSettings,
  getGallery,
  getGalleryCarouselImages,
  getHomePage,
  getSiteSettings,
  getSponsors,
  multilineToHtml,
} from '../lib/content';

const settings = await getSiteSettings();
const home = await getHomePage();
const about = await getAboutPage();
const heroBgUrl = home.heroImage ? imageUrl(home.heroImage) : null;
const achievementsPage = await getAchievementsPage();
const leagues = achievementsPage.leagues;
const sponsorsDoc = await getSponsors();
const footer = await getFooterSettings();
const gallery = await getGallery();
const images = await getGalleryCarouselImages();

const fallbackImages = [
  { id: 'fallback-1', src: '/images/eagles.avif', alt: 'Eagles United action shot' },
  { id: 'fallback-2', src: '/images/eagles2.avif', alt: 'Eagles United action shot' },
  { id: 'fallback-3', src: '/images/eagles3.avif', alt: 'Eagles United action shot' },
  { id: 'fallback-4', src: '/images/eagles4.avif', alt: 'Eagles United action shot' },
];

const displayImages = images && images.length > 0 ? images : fallbackImages;

const storyParagraphs = blocksToParagraphs(about.story);

const liveNews = await sanityClient.fetch<any[]>('*[_type == "news"] | order(date desc) { title, date, excerpt, "image": image.asset->url }');

const formatDate = (dateStr: string) => {
  if (!dateStr) return '';
  try {
    const parts = dateStr.split('-');
    if (parts.length !== 3) return dateStr;
    const [year, month, day] = parts;
    const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    const monthIndex = parseInt(month, 10) - 1;
    const formattedDay = parseInt(day, 10);
    return `${formattedDay} ${months[monthIndex]} ${year}`;
  } catch (e) {
    return dateStr;
  }
};

const temporaryNews = [
  {
    title: "Looking for a womens football team for next season",
    date: "15 May 2026",
    excerpt: "Nothing too serious but ambitious. Join Eagles United WFC.",
    image: "/images/eagles5.avif",
    tag: "Recruitment"
  },
  {
    title: "Training",
    date: "10 May 2026",
    excerpt: "Players & Goalkeeper wanted!",
    image: "/images/eagles6.avif",
    tag: "Training"
  },
  {
    title: "Sponsors required",
    date: "5 May 2026",
    excerpt: "Local businesses, your chance to make an impact!",
    image: "/images/eagles7.avif",
    tag: "Sponsors"
  }
];

---

<BaseLayout
  title="Eagles United WFC | Women's Football in Haringey"
  description={home.heroSubtitle}
  settings={settings}
  footer={footer}
>
  <section class="relative overflow-hidden border-b border-white/10">
    {heroBgUrl && (
    <div 
      class="absolute inset-0 bg-cover bg-center bg-no-repeat opacity-40 mix-blend-overlay"
      style={`background-image: url('${heroBgUrl}');`}
    ></div>
  )}
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(225,29,72,0.25),transparent_55%)]"></div>
    <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(26,26,26,0.2),rgba(26,26,26,1))]"></div>

    <div class="relative mx-auto flex max-w-6xl flex-col items-center gap-8 px-4 py-16 text-center sm:px-6 sm:py-24 lg:px-8">
      <img
        src="/images/EaglesUnitedWFC_Logo.png"
        alt="Eagles United WFC logo"
        width="140"
        height="140"
        class="h-28 w-28 animate-heartbeat rounded-full ring-4 ring-white/15 sm:h-36 sm:w-36"
        loading="eager"
      />
      <div class="max-w-3xl space-y-4">
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-eagles-red">Est. 2024</p>
        <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl">
          {home.heroTitle}
        </h1>
        <p class="text-lg text-white/80 sm:text-xl">{home.heroSubtitle}</p>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-3">
        
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-4xl px-4 pt-12 sm:px-6 sm:pt-16 lg:px-8">
      <div class="group relative h-64 w-full overflow-hidden rounded-2xl border border-white/10 shadow-2xl sm:h-80 md:h-96 lg:h-[30rem]">
        <img
          src="/images/eagles1.avif"
          alt="Eagles United WFC Team Squad"
          class="h-full w-full object-cover object-center transition duration-700 group-hover:scale-105"
          loading="lazy"
        />
        <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-charcoal/60 to-transparent"></div>
      </div>
    </div>

  <section id="about">
    <div class="border-b border-white/10 bg-charcoal-light/30 py-14 sm:py-20">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <SectionHeading eyebrow="About" title={about.pageTitle ?? 'Our Story'} />
        <div class="mt-8 space-y-5 text-base leading-relaxed text-white/85 sm:text-lg">
          {
            storyParagraphs.map((paragraph) => <p>{paragraph}</p>)
          }
          {about.missionStatement && <p class="font-medium text-white">{about.missionStatement}</p>}
          {about.coachNote && <p>{about.coachNote}</p>}
          {about.trainingNote && <p>{about.trainingNote}</p>}
        </div>
      </div>
    </div>

    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
      <SectionHeading title="Our Values" />
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {
          about.values?.map((value) => (
            <div class="relative group z-0 isolate flex flex-col h-full">
              <div class="absolute inset-0 rounded-2xl bg-white/[0.01] border border-white/5 translate-x-3 translate-y-3 rotate-1 -z-20 transition duration-500 group-hover:translate-x-4 group-hover:translate-y-4 group-hover:rotate-2"></div>
              <div class="absolute inset-0 rounded-2xl bg-white/[0.02] border border-white/5 translate-x-1.5 translate-y-1.5 -rotate-1 -z-10 transition duration-500 group-hover:translate-x-2 group-hover:translate-y-2 group-hover:-rotate-2"></div>
              <article class="flex flex-col flex-1 rounded-2xl backdrop-blur-xl bg-white/5 border border-white/10 shadow-[0_4px_30px_rgba(0,0,0,0.1)] hover:bg-white/10 hover:border-eagles-red/40 hover:shadow-[0_0_20px_rgba(225,29,72,0.35),0_4px_30px_rgba(0,0,0,0.1)] p-6 transition duration-300">
                <h3 class="mb-3 text-lg font-bold text-eagles-red">{value.title}</h3>
                <p class="text-sm leading-relaxed text-white/80 sm:text-base flex-1">{value.description}</p>
              </article>
            </div>
          ))
        }
      </div>
    </div>

    <div class="border-t border-white/10 bg-charcoal-light/30 py-16">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <SectionHeading
          title={achievementsPage.title ?? 'Leagues and achievements'}
        />
        {achievementsPage.achievements && achievementsPage.achievements.length > 0 && (
          <JukeboxAchievements client:load achievements={achievementsPage.achievements} />
        )}
        {leagues && leagues.length > 0 && (
          <>
            <br />
            <p class="mt-8 text-sm text-white/60">
              Follow our progress in the
              {leagues.map((league, idx) => (
                <>
                  {idx > 0 && idx === leagues.length - 1 ? ' and the ' : idx > 0 ? ', the ' : ' '}
                  <a
                    href={league.url}
                    class="text-eagles-red underline-offset-2 hover:underline"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {league.name}
                  </a>
                </>
              ))}
              .
            </p>
          </>
        )}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-6 md:grid-cols-3">
      <InfoCard
        title={home.trainingHeading ?? 'Training'}
        body={multilineToHtml(home.trainingDetails)}
      />
      <InfoCard
        title={home.ageGroupHeading ?? 'Age Group'}
        body={multilineToHtml(home.ageGroupDetails)}
      />
      <InfoCard
        title={home.priceHeading ?? 'Price'}
        body={multilineToHtml(home.priceDetails)}
      />
    </div>
  </section>

  <section class="relative overflow-hidden border-y border-white/10 bg-charcoal-light/40 py-16">
    <div class="absolute -top-20 left-1/2 h-64 w-64 -translate-x-1/2 rounded-full bg-eagles-red/20 blur-[100px] pointer-events-none animate-breath"></div>
    <div class="relative mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <SectionHeading title={home.ctaHeading ?? 'Ready to join?'} subtitle={home.ctaText} />
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a
          href="#contact"
          class="rounded-full bg-eagles-red px-6 py-3 text-sm font-bold uppercase tracking-wide text-white transition hover:bg-eagles-red-dark"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>

  <section id="news" class="border-y border-white/10 bg-charcoal-light/30 py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        eyebrow="Latest"
        title="Club News"
        subtitle="Updates from training, matches and the Eagles United community."
      />
   <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
  {
    liveNews.map((item) => (
      <div class="relative group z-0 isolate flex flex-col h-full">
        <div class="absolute inset-0 rounded-2xl bg-white/[0.01] border border-white/5 translate-x-3 translate-y-3 rotate-1 -z-20 transition duration-500 group-hover:translate-x-4 group-hover:translate-y-4 group-hover:rotate-2"></div>
        <div class="absolute inset-0 rounded-2xl bg-white/[0.02] border border-white/5 translate-x-1.5 translate-y-1.5 -rotate-1 -z-10 transition duration-500 group-hover:translate-x-2 group-hover:translate-y-2 group-hover:-rotate-2"></div>
        <article class="flex flex-col flex-1 overflow-hidden rounded-2xl backdrop-blur-xl bg-white/5 border border-white/10 shadow-[0_4px_30px_rgba(0,0,0,0.1)] hover:bg-white/10 hover:border-eagles-red/40 hover:shadow-[0_0_20px_rgba(225,29,72,0.35),0_4px_30px_rgba(0,0,0,0.1)] transition duration-300">
          
          <div class="relative h-48 w-full shrink-0 overflow-hidden bg-charcoal/80 sm:h-56">
            <img 
              src={item.image} 
              alt={item.title} 
              class="news-image h-full w-full cursor-pointer object-contain transition duration-300 hover:scale-105" 
              title="Double-click to enlarge"
              loading="lazy" 
            />
          </div>

          <div class="flex flex-1 flex-col p-6">
            <span class="mb-2 text-xs font-bold uppercase tracking-[0.2em] text-eagles-red">
              {formatDate(item.date)}
            </span>
            <h3 class="mb-3 text-lg font-bold text-white">{item.title}</h3>
            <p class="flex-1 text-sm leading-relaxed text-white/70 line-clamp-3">
              {item.excerpt}
            </p>
          </div>

        </article>
      </div>
    ))
  }
</div>
    </div>
  </section>

  <section id="gallery" class="mx-auto max-w-5xl px-4 py-14 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow="Club Life"
      title={gallery.title ?? 'Gallery'}
      subtitle={gallery.description}
    />

    <div class="mt-10">
      <GalleryCarousel client:load images={displayImages} transitionInterval={gallery.transitionInterval} />
    </div>
  </section>

  <section id="sponsors">
    <Sponsors sponsors={sponsorsDoc.sponsors} />
  </section>

  <section id="contact" class="relative overflow-hidden">
    <div class="absolute -top-20 left-1/2 h-64 w-64 -translate-x-1/2 rounded-full bg-eagles-red/20 blur-[100px] pointer-events-none animate-breath"></div>
    <div class="relative border-b border-white/10 bg-charcoal-light/30 py-14 sm:py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <SectionHeading
          eyebrow="Contact"
          title={settings.contactSectionTitle ?? 'Get in Touch'}
          subtitle={settings.contactSectionSubtitle ?? "Whether you're looking to join our Thursday training sessions, inquire about sponsorship opportunities, or just say hello, drop us a message."}
        />
      </div>
    </div>

    <div class="relative mx-auto max-w-2xl px-4 py-14">
      <ContactForm />
    </div>
  </section>

  <div id="image-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/95 p-4 opacity-0 transition-opacity duration-300">
  <button id="close-modal" class="absolute right-6 top-6 rounded-full bg-white/10 p-2 text-white transition hover:bg-eagles-red hover:text-white">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
  <img id="modal-image" src="" alt="Enlarged view" class="max-h-[90vh] max-w-[90vw] rounded-lg object-contain shadow-2xl" />
</div>

<script>
  const images = document.querySelectorAll('.news-image');
  const modal = document.getElementById('image-modal');
  const modalImg = document.getElementById('modal-image') as HTMLImageElement;
  const closeBtn = document.getElementById('close-modal');

  // Open modal on double click
  images.forEach(img => {
    img.addEventListener('dblclick', (e) => {
      if (modal && modalImg && e.target instanceof HTMLImageElement) {
        modalImg.src = e.target.src;
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        
        // Slight delay to allow display:flex to apply before transitioning opacity
        setTimeout(() => {
          modal.classList.remove('opacity-0');
          modal.classList.add('opacity-100');
        }, 10);
      }
    });
  });

  // Close modal logic
  const closeModal = () => {
    if (modal) {
      modal.classList.remove('opacity-100');
      modal.classList.add('opacity-0');
      setTimeout(() => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        if (modalImg) modalImg.src = '';
      }, 300); // Matches the duration-300 class
    }
  };

  closeBtn?.addEventListener('click', closeModal);
  
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal(); // Close if clicking the background
  });
  
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal?.classList.contains('hidden')) {
      closeModal();
    }
  });
</script>

</BaseLayout>
