---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { defaultContact } from '../lib/fallbacks';
import { getSiteSettings, multilineToHtml } from '../lib/content';

const settings = await getSiteSettings();
const email = settings.contactEmail ?? 'eaglesuniteduk@gmail.com';
const address = settings.address ?? defaultContact.location;
---

<BaseLayout
  title="Contact Eagles United WFC"
  description="Join Thursday training, sponsorship enquiries, or say hello to Eagles United WFC."
  settings={settings}
>
  <section class="border-b border-white/10 bg-charcoal-light/30 py-14 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        eyebrow="Contact"
        title={defaultContact.pageTitle}
        subtitle={defaultContact.intro}
      />
    </div>
  </section>

  <section class="mx-auto grid max-w-6xl gap-10 px-4 py-14 sm:px-6 lg:grid-cols-2 lg:px-8">
    <div class="space-y-8">
      <article class="rounded-2xl border border-white/10 bg-charcoal-light/70 p-6">
        <h2 class="mb-2 text-xs font-bold uppercase tracking-[0.2em] text-eagles-red">Location</h2>
        <div class="text-sm leading-relaxed text-white/85 sm:text-base" set:html={multilineToHtml(address)} />
      </article>

      <article class="rounded-2xl border border-white/10 bg-charcoal-light/70 p-6">
        <h2 class="mb-2 text-xs font-bold uppercase tracking-[0.2em] text-eagles-red">Email</h2>
        <a href={`mailto:${email}`} class="text-base font-medium text-white hover:text-eagles-red">
          {email}
        </a>
      </article>

      <article class="rounded-2xl border border-white/10 bg-charcoal-light/70 p-6">
        <h2 class="mb-2 text-xs font-bold uppercase tracking-[0.2em] text-eagles-red">
          Training Times
        </h2>
        <p class="text-sm text-white/85 sm:text-base">{defaultContact.trainingTimes}</p>
      </article>
    </div>

    <div>
      <h2 class="mb-4 text-xl font-bold">Send a Message</h2>
      <ContactForm email={email} />
    </div>
  </section>
</BaseLayout>
