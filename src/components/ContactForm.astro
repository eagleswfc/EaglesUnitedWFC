---
interface Props {
  email: string;
}

const { email } = Astro.props;
---

<form
  id="contact-form"
  class="space-y-5 rounded-2xl border border-white/10 bg-charcoal-light/80 p-6 sm:p-8"
  novalidate
>
  <div class="grid gap-5 sm:grid-cols-2">
    <label class="block space-y-2 text-sm">
      <span class="font-semibold text-white/90">Name</span>
      <input
        type="text"
        name="name"
        required
        class="w-full rounded-xl border border-white/15 bg-charcoal px-4 py-3 text-white outline-none transition focus:border-eagles-red"
        placeholder="Your name"
      />
    </label>
    <label class="block space-y-2 text-sm">
      <span class="font-semibold text-white/90">Email</span>
      <input
        type="email"
        name="from"
        required
        class="w-full rounded-xl border border-white/15 bg-charcoal px-4 py-3 text-white outline-none transition focus:border-eagles-red"
        placeholder="you@example.com"
      />
    </label>
  </div>

  <label class="block space-y-2 text-sm">
    <span class="font-semibold text-white/90">Message</span>
    <textarea
      name="message"
      rows="6"
      required
      class="w-full resize-y rounded-xl border border-white/15 bg-charcoal px-4 py-3 text-white outline-none transition focus:border-eagles-red"
      placeholder="Tell us how we can help..."
    ></textarea>
  </label>

  <button
    type="submit"
    class="inline-flex w-full items-center justify-center rounded-full bg-eagles-red px-6 py-3 text-sm font-bold uppercase tracking-wide text-white transition hover:bg-eagles-red-dark sm:w-auto"
  >
    Send Message
  </button>
</form>

<script define:vars={{ email }}>
  const form = document.getElementById('contact-form');
  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    const data = new FormData(form);
    const name = data.get('name');
    const from = data.get('from');
    const message = data.get('message');
    const subject = encodeURIComponent('Eagles United WFC enquiry');
    const body = encodeURIComponent(
      `Name: ${name}\nEmail: ${from}\n\n${message}`,
    );
    window.location.href = `mailto:${email}?subject=${subject}&body=${body}`;
  });
</script>
