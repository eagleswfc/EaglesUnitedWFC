<form
  id="contact-form"
  class="space-y-5 rounded-2xl border border-white/10 bg-charcoal-light/80 p-6 sm:p-8"
  novalidate
>
  <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE">
  <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

  <h2 class="text-xl font-bold text-white">Send a Message</h2>
  
  <div class="grid gap-5 sm:grid-cols-2">
    <label class="block space-y-2 text-sm">
      <span class="font-semibold text-white/90">Name</span>
      <input
        type="text"
        id="form-name"
        name="name"
        required
        class="w-full rounded-xl border border-white/15 bg-charcoal px-4 py-3 text-white outline-none transition focus:border-eagles-red"
        placeholder="Your name"
      />
      <span id="error-name" class="hidden text-xs font-medium text-eagles-red">Please enter your name.</span>
    </label>

    <label class="block space-y-2 text-sm">
      <span class="font-semibold text-white/90">Email</span>
      <input
        type="email"
        id="form-email"
        name="email"
        required
        class="w-full rounded-xl border border-white/15 bg-charcoal px-4 py-3 text-white outline-none transition focus:border-eagles-red"
        placeholder="you@example.com"
      />
      <span id="error-email" class="hidden text-xs font-medium text-eagles-red">Please enter a valid email address.</span>
    </label>
  </div>

  <label class="block space-y-2 text-sm">
    <span class="font-semibold text-white/90">Message</span>
    <textarea
      id="form-message"
      name="message"
      rows="6"
      required
      class="w-full resize-y rounded-xl border border-white/15 bg-charcoal px-4 py-3 text-white outline-none transition focus:border-eagles-red"
      placeholder="Tell us how we can help..."
    ></textarea>
    <span id="error-message" class="hidden text-xs font-medium text-eagles-red">Please enter a message.</span>
  </label>

  <button
  type="submit"
  id="submit-btn"
  disabled
  class="inline-flex w-full items-center justify-center rounded-full bg-eagles-red px-6 py-3 text-sm font-bold uppercase tracking-wide text-white transition hover:bg-eagles-red-dark disabled:cursor-not-allowed disabled:bg-white/10 disabled:text-white/50 sm:w-auto"
>
  Send Message
</button>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const nameInput = document.getElementById('form-name') as HTMLInputElement;
  const emailInput = document.getElementById('form-email') as HTMLInputElement;
  const messageInput = document.getElementById('form-message') as HTMLTextAreaElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  const errorName = document.getElementById('error-name');
  const errorEmail = document.getElementById('error-email');
  const errorMessage = document.getElementById('error-message');

  // Simple regex to verify standard email format
  const isValidEmail = (email: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);

  // Checks individual field validity and shows/hides error text
  const checkField = (field: 'name' | 'email' | 'message', showErrors = false) => {
    let isValid = false;

    if (field === 'name') {
      isValid = nameInput.value.trim().length > 0;
      if (showErrors) errorName?.classList.toggle('hidden', isValid);
    } 
    else if (field === 'email') {
      isValid = isValidEmail(emailInput.value.trim());
      if (showErrors) errorEmail?.classList.toggle('hidden', isValid);
    } 
    else if (field === 'message') {
      isValid = messageInput.value.trim().length > 0;
      if (showErrors) errorMessage?.classList.toggle('hidden', isValid);
    }

    return isValid;
  };

  // Checks the whole form to unlock the submit button
  const checkFormValidity = () => {
    const isNameValid = checkField('name');
    const isEmailValid = checkField('email');
    const isMessageValid = checkField('message');

    submitBtn.disabled = !(isNameValid && isEmailValid && isMessageValid);
  };

  // Event Listeners: Check silently while typing to unlock the button
  nameInput?.addEventListener('input', checkFormValidity);
  emailInput?.addEventListener('input', checkFormValidity);
  messageInput?.addEventListener('input', checkFormValidity);

  // Event Listeners: Show red error text if they leave a field empty/invalid
  nameInput?.addEventListener('blur', () => checkField('name', true));
  emailInput?.addEventListener('blur', () => checkField('email', true));
  messageInput?.addEventListener('blur', () => checkField('message', true));

  // Handle actual submission (Assuming Web3Forms fetch setup)
  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    
    // Safety check just in case they bypassed the disabled button
    if (submitBtn.disabled) return;

    submitBtn.innerText = 'Sending...';
    submitBtn.disabled = true;

    try {
      const formData = new FormData(form);
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: formData
      });

      if (response.ok) {
        submitBtn.innerText = 'Message Sent!';
        submitBtn.classList.add('!bg-green-600', '!text-white');
        form.reset();
        
        // Reset button after 3 seconds
        setTimeout(() => {
          submitBtn.innerText = 'Send Message';
          submitBtn.classList.remove('!bg-green-600', '!text-white');
          checkFormValidity(); // Re-disable since form is empty now
        }, 3000);
      } else {
        throw new Error('Failed to send');
      }
    } catch (error) {
      submitBtn.innerText = 'Error. Try Again.';
      submitBtn.disabled = false;
    }
  });
</script>