---
import { defaultFooterSettings, defaultSocialLinks } from "../lib/fallbacks";
import { navLinks } from "../lib/navigation";
import type { FooterSettings, SiteSettings } from "../lib/types";

interface Props {
  settings: SiteSettings;
  footer: FooterSettings;
}

const { settings, footer } = Astro.props;
const email = footer.contactEmail ?? defaultFooterSettings.contactEmail ?? "eaglesuniteduk@gmail.com";
const address = footer.address ?? defaultFooterSettings.address ?? "";
const trainingTimes = footer.trainingTimes ?? defaultFooterSettings.trainingTimes ?? "Thursday 7pm to 8:30pm (£7 per session)";
const year = new Date().getFullYear();

const socialLinks = footer.socialLinks?.length
  ? footer.socialLinks
  : defaultFooterSettings.socialLinks ?? defaultSocialLinks;
---

<footer class="border-t border-white/10 bg-charcoal-light">
  <div
    class="mx-auto grid max-w-6xl gap-10 px-4 py-12 sm:px-6 sm:grid-cols-2 lg:grid-cols-5 lg:px-8"
  >
    <div class="space-y-4">
      <a href="/" class="inline-flex items-center gap-3">
        <img
          src="/images/eaglesunitedwfc_logo.jpg"
          alt="Eagles United WFC"
          width="64"
          height="64"
          class="h-16 w-16 rounded-full ring-2 ring-white/15"
          loading="lazy"
        />
        <div>
          <p class="text-sm font-bold tracking-[0.18em]">EAGLES UNITED WFC</p>
          <p class="text-xs text-white/60">Est. 2024 · Haringey, London</p>
        </div>
      </a>
    </div>

    <div>
      <h2
        class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-eagles-red"
      >
        Contact
      </h2>
      <div class="space-y-4">
        <a
          href={`mailto:${email}`}
          class="flex items-center gap-3 text-sm text-white/75 transition hover:text-white"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-4 w-4 shrink-0 opacity-75"
            aria-hidden="true"
          >
            <rect width="20" height="16" x="2" y="4" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>
          {email}
        </a>
        <div class="flex items-start gap-3 text-sm text-white/75">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="mt-0.5 h-4 w-4 shrink-0 opacity-75"
            aria-hidden="true"
          >
            <path
              d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"
            ></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          <address class="not-italic leading-relaxed">
            {
              address.split("\n").map((line) => (
                <>
                  {line}
                  <br />
                </>
              ))
            }
          </address>
        </div>
        {
          footer.contactPhone && (
            <a
              href={`tel:${footer.contactPhone}`}
              class="flex items-center gap-3 text-sm text-white/75 transition hover:text-white"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-4 w-4 shrink-0 opacity-75"
                aria-hidden="true"
              >
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
              </svg>
              {footer.contactPhone}
            </a>
          )
        }
      </div>
    </div>

    <div>
      <h2
        class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-eagles-red"
      >
        Training Times
      </h2>
      <p class="text-sm text-white/75">
        {trainingTimes}
      </p>
    </div>

    <div>
      <h2
        class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-eagles-red"
      >
        Explore
      </h2>
      <ul class="space-y-2 text-sm">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-white/75 transition hover:text-white"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h2
        class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-eagles-red"
      >
        Follow Us
      </h2>
      <ul class="flex flex-wrap items-center gap-4">
        {
          socialLinks?.map((link) => (
            <li>
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Follow us on ${link.platform}`}
                class="group block transition-transform hover:scale-110"
              >
                <img
                  src={`/${link.platform}.svg`}
                  alt={`${link.platform} logo`}
                  class="h-6 w-6 rounded-lg object-cover opacity-75 transition group-hover:opacity-100"
                />
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10 py-4 text-xs text-white/50">
    <div
      class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4"
    >
      <p class="text-center sm:text-left">
        © {year} Eagles United WFC. FA Affiliated{
          footer.faAffiliationId ? ` · ID ${footer.faAffiliationId}` : ""
        }.
      </p>
      <div class="flex items-center gap-2">
        <span>Developed by:</span>
        <a
          href="https://www.slick-it-solutions.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block"
        >
          <img
            src="/slick-logo.png"
            alt="Slick Logo"
            class="h-5 w-auto object-contain opacity-75 hover:opacity-100 transition duration-200"
            loading="lazy"
          />
        </a>
      </div>
    </div>
  </div>
</footer>
