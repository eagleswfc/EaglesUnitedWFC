---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, subtitle, align = 'center' } = Astro.props;
---

<div class:list={['max-w-3xl', align === 'center' && 'mx-auto text-center']}>
  {
    eyebrow && (
      <p class="mb-3 text-xs font-bold uppercase tracking-[0.25em] text-eagles-red">{eyebrow}</p>
    )
  }
  <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">{title}</h2>
  {
    subtitle && <p class="mt-4 text-base text-white/75 sm:text-lg">{subtitle}</p>
  }
</div>
