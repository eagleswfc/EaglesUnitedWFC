---
import { navLinks } from '../lib/navigation';
import type { SiteSettings } from '../lib/types';

interface Props {
  settings: SiteSettings;
}

const { settings } = Astro.props;
const siteTitle = settings.siteTitle ?? 'Eagles United WFC';
---

<header class="sticky top-0 z-40 border-b border-white/10 bg-charcoal/95 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8">
    
    <a href="/" class="group flex shrink-0 items-center gap-3" aria-label={`${siteTitle} home`}>
      <img
        src="/images/EaglesUnitedWFC_Logo.png"
        alt={`${siteTitle} logo`}
        width="56"
        height="56"
        class="h-12 w-12 rounded-full ring-2 ring-white/20 transition group-hover:ring-eagles-red sm:h-14 sm:w-14"
        loading="eager"
      />
      <span class="hidden text-sm font-bold tracking-[0.2em] text-white sm:inline lg:text-base">
        EAGLES UNITED WFC
      </span>
    </a>

    <nav aria-label="Desktop navigation" class="hidden sm:block">
      <ul class="flex items-center gap-2">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="rounded-full px-4 py-2 text-sm font-semibold uppercase tracking-wide text-white/80 transition hover:bg-white/10 hover:text-white active:bg-eagles-red active:text-white"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <button 
      id="mobile-menu-btn" 
      class="block p-2 text-white/80 transition hover:text-white sm:hidden" 
      aria-label="Toggle mobile menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-8 w-8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </div>

  <nav 
    id="mobile-menu" 
    class="hidden flex-col border-t border-white/10 bg-charcoal-light/95 px-4 py-6 sm:hidden" 
    aria-label="Mobile navigation"
  >
    <ul class="flex flex-col gap-4">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="mobile-link block w-full rounded-lg bg-white/5 px-4 py-3 text-center text-sm font-bold uppercase tracking-wide text-white transition hover:bg-eagles-red active:bg-eagles-red-dark"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  // Client-side script to handle the mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  // Toggle menu on burger click
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex');
  });

  // Close menu when a link is clicked (crucial for single-page scrolling)
  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      menu?.classList.remove('flex');
    });
  });
</script>