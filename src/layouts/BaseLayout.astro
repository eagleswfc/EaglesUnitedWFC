---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { FooterSettings, SiteSettings } from '../lib/types';

interface Props {
  title?: string;
  description?: string;
  settings: SiteSettings;
  footer: FooterSettings;
}

const {
  title = 'Eagles United WFC',
  description = "Women's football in Haringey — community, confidence and the love of the game.",
  settings,
  footer,
} = Astro.props;

const pageTitle = title.includes('Eagles United') ? title : `${title} | Eagles United WFC`;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/images/EaglesUnitedWFC_Logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
  </head>
  <body class="flex min-h-screen flex-col overflow-x-hidden bg-charcoal text-white antialiased">
    <Header settings={settings} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer settings={settings} footer={footer} />
  </body>
</html>
